{
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "includeFiles": [
        "tablyci/**",
        "fonts/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
