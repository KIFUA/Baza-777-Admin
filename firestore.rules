rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: Is the user an admin?
    // For now, allow admin access to kostel.if.ua@gmail.com if they are authenticated.
    // In a real app, use custom claims or a dedicated admins collection.
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'kostel.if.ua@gmail.com';
    }

    // Default deny
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
