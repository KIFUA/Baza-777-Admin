{
  "framework": "vite",
  "functions": {
    "api/index.cjs": {
      "includeFiles": [
        "tablyci/**",
        "fonts/**",
        "dist/server.cjs",
        "dist/server.cjs.map"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.cjs"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
